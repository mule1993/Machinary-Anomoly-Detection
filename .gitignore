# ==========================================
# 1. PYTHON ENVIRONMENT & ORCHESTRATION
# ==========================================
.venv/
venv/
__pycache__/
*.pyc
.env
.gitignore.bak
.astro/

# ==========================================
# 2. GLOBAL EXTENSIONS (BLOCK LARGE FILES)
# ==========================================
*.csv
*.parquet
*.tar.gz
*.joblib
*.pkl

# ==========================================
# 3. DATA DIRECTORY & DVC EXCEPTIONS
# ==========================================
# Target contents inside data, but allow Git to read the folder structure
/data/*
/data/**/*

# EXCEPTION: Whitelist all DVC tracking files everywhere
!*.dvc
!/**/.dvc
!/data/**/*.dvc