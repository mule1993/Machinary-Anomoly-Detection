# Tell Git to ignore files INSIDE data, but allow it to read the folder structure
/data/**

# EXCEPTION: Explicitly allow the .dvc metadata files
!/data/**/*.dvc

# Global file patterns to block large binaries elsewhere
*.csv
*.parquet
*.tar.gz
*.joblib
*.pkl

# Python environment & orchestration files
.venv/
__pycache__/
.env
.astro/